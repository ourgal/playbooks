    "zxc.20260131235917.4": "- name: Create folder\n  ansible.windows.win_file:\n    path: D:/{{ item }}\n    state: directory\n  loop:\n    @others\n",
    "zxc.20260131235917.6": "- name: Link to new folder\n  ansible.windows.win_shell: |\n    & cmd /c \"mklink /j \"\"{{ ansible_facts.user_dir }}\\{{ item }}\"\" \"\"D:\\{{ item }}\"\"\"\n  loop:\n    @others\n",
    "zxc.20260131235857.1": "- name: Link scoop folder\n  tags: scoop_folder\n  block:\n    - name: Create folder\n      ansible.windows.win_file:\n        path: \"{{ item }}\"\n        state: directory\n      loop:\n        - D:\\scoop_apps\n        - \"{{ ansible_facts.user_dir }}\\\\scoop\"\n    - name: Remove target folder\n      ansible.windows.win_file:\n        path: \"{{ ansible_facts.user_dir }}\\\\scoop\\\\apps\"\n        state: absent\n    - name: Create scoop folder\n      ansible.windows.win_shell: |\n        & cmd /c \"mklink /j {{ ansible_facts.user_dir }}\\scoop\\apps D:\\scoop_apps\"\n",
